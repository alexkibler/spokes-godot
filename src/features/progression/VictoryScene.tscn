[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/features/progression/VictoryScene.gd" id="1_v1v1v"]

[node name="VictoryScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_v1v1v")

[node name="ColorRect" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.1, 0.05, 1)

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 40

[node name="Label" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 64
text = "RUN COMPLETE!"
horizontal_alignment = 1

[node name="StatsGrid" type="GridContainer" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/h_separation = 50
theme_override_constants/v_separation = 15
columns = 2

[node name="TimeLabel" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Total Time:"

[node name="TimeValue" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "00:00:00"
horizontal_alignment = 2

[node name="DistLabel" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Total Distance:"

[node name="DistValue" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "0.0 km"
horizontal_alignment = 2

[node name="ElevLabel" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Total Elevation:"

[node name="ElevValue" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "0 m"
horizontal_alignment = 2

[node name="WorkLabel" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Total Work:"

[node name="WorkValue" type="Label" parent="CenterContainer/VBoxContainer/StatsGrid"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "0 kJ"
horizontal_alignment = 2

[node name="ReturnButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(300, 80)
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "RETURN TO MENU"

[connection signal="pressed" from="CenterContainer/VBoxContainer/ReturnButton" to="." method="_on_return_pressed"]
