[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/ui/components/SaveSlot.gd" id="1_slot"]

[node name="SaveSlot" type="MarginContainer"]
custom_minimum_size = Vector2(0, 120)
offset_right = 400.0
offset_bottom = 120.0
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10
script = ExtResource("1_slot")

[node name="PanelContainer" type="PanelContainer" parent="."]
layout_mode = 2

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2

[node name="EmptyView" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
visible = false
layout_mode = 2
size_flags_vertical = 3
alignment = 1

[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/EmptyView"]
layout_mode = 2
size_flags_horizontal = 3
text = "— EMPTY SLOT —"
horizontal_alignment = 1

[node name="NewGameBtn" type="Button" parent="PanelContainer/VBoxContainer/EmptyView"]
layout_mode = 2
text = "NEW GAME"

[node name="DataView" type="VBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="HBoxContainer" type="HBoxContainer" parent="PanelContainer/VBoxContainer/DataView"]
layout_mode = 2

[node name="GoldLabel" type="Label" parent="PanelContainer/VBoxContainer/DataView/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
text = "Gold: 0"

[node name="DistLabel" type="Label" parent="PanelContainer/VBoxContainer/DataView/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
text = "Dist: 0.0 km"

[node name="DiffLabel" type="Label" parent="PanelContainer/VBoxContainer/DataView/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
text = "Normal"

[node name="DeleteButton" type="Button" parent="PanelContainer/VBoxContainer/DataView/HBoxContainer"]
layout_mode = 2
text = "X"

[node name="DateLabel" type="Label" parent="PanelContainer/VBoxContainer/DataView"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.5, 0.5, 1)
theme_override_font_sizes/font_size = 12
text = "YYYY-MM-DD HH:MM"
horizontal_alignment = 2

[node name="OverlayBtn" type="Button" parent="."]
layout_mode = 2
flat = true

[connection signal="pressed" from="PanelContainer/VBoxContainer/EmptyView/NewGameBtn" to="." method="_on_select_button_pressed"]
[connection signal="pressed" from="PanelContainer/VBoxContainer/DataView/HBoxContainer/DeleteButton" to="." method="_on_delete_button_pressed"]
[connection signal="pressed" from="OverlayBtn" to="." method="_on_select_button_pressed"]
